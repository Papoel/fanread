{% extends 'base.html.twig' %}

{% block title %}Inscription
{% endblock %}

{% block body %}
	<div
		class="min-h-screen flex flex-col lg:flex-row bg-background">

		{# ================================================================
		       COLONNE GAUCHE — héros décoratif (desktop uniquement)
		    ================================================================ #}
		<div
			class="hidden lg:flex lg:w-1/2 relative overflow-hidden items-center justify-center">

			{# Image de fond + overlays #}
			<div class="absolute inset-0" style="background-image: url('https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1200&q=85');
					                    background-size: cover; background-position: center;">
				<div class="absolute inset-0" style="background: linear-gradient(135deg,
					                     hsl(var(--primary) / 0.88) 0%,
					                     hsl(var(--secondary) / 0.75) 55%,
					                     hsl(var(--accent) / 0.85) 100%);"></div>
			</div>

			<div
				class="relative z-10 p-14 text-white max-w-md w-full">

				{# Logo #}
				<a href="{{ path('app_home') }}" class="flex items-center gap-3 mb-14 group">
					<div class="p-2.5 rounded-xl transition-transform duration-300 group-hover:scale-110" style="background: rgba(255,255,255,0.20);">
						<svg class="h-7 w-7 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="currentColor"/>
						</svg>
					</div>
					<span class="text-2xl font-bold font-heading">FanRead</span>
				</a>

				{# Accroche #}
				<h2 class="font-heading font-bold text-4xl mb-4 leading-tight">
					Votre bibliothèque<br>personnelle vous attend.
				</h2>
				<p class="text-white/80 text-lg leading-relaxed mb-12 font-body">
					Rejoignez FanRead et commencez à collectionner vos lectures, noter vos impressions et suivre votre progression.
				</p>

				{# Liste des avantages #}
				<ul class="space-y-4">
					<li class="flex items-center gap-3">
						<div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.18);">
							<svg class="w-4 h-4 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
							</svg>
						</div>
						<span class="text-white/90 font-semibold font-body">Cataloguez toutes vos lectures</span>
					</li>
					<li class="flex items-center gap-3">
						<div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.18);">
							<svg class="w-4 h-4 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
							</svg>
						</div>
						<span class="text-white/90 font-semibold font-body">Notez et partagez vos coups de cœur</span>
					</li>
					<li class="flex items-center gap-3">
						<div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.18);">
							<svg class="w-4 h-4 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
							</svg>
						</div>
						<span class="text-white/90 font-semibold font-body">Visualisez vos statistiques de lecture</span>
					</li>
				</ul>
			</div>
		</div>

		{# ================================================================
		       COLONNE DROITE — formulaire
		    ================================================================ #}
		<div
			class="w-full lg:w-1/2 flex flex-col items-center justify-center min-h-screen p-6 sm:p-12 animate-fade-in-up">

			{# Logo mobile (masqué sur desktop) #}
			<div class="lg:hidden w-full max-w-md mb-10">
				<a href="{{ path('app_home') }}" class="flex items-center gap-2">
					<div class="p-2 rounded-xl bg-muted">
						<svg class="h-6 w-6 text-primary" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="currentColor"/>
						</svg>
					</div>
					<span class="text-2xl font-bold font-heading text-foreground">FanRead</span>
				</a>
			</div>

			<div
				class="w-full max-w-md">

				{# En-tête de section #}
				<div class="mb-8">
					<h1 class="font-heading font-bold text-3xl text-foreground mb-2">Créer un compte</h1>
					<p class="text-muted-foreground font-body text-sm">
						Déjà un compte ?
						<a href="{{ path('app_login') }}" class="text-primary font-semibold hover:underline underline-offset-2 transition-colors">
							Se connecter
						</a>
					</p>
				</div>

				{# ── Alerte erreur vérification email ── #}
				{% for flash_error in app.flashes('verify_email_error') %}
					<div class="flex items-start gap-3 p-4 mb-6 rounded-xl border" style="background-color: hsl(var(--destructive) / 0.07); border-color: hsl(var(--destructive) / 0.30);">
						<svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: hsl(var(--destructive));" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="12" cy="12" r="10"/>
							<line x1="12" y1="8" x2="12" y2="12"/>
							<line x1="12" y1="16" x2="12.01" y2="16"/>
						</svg>
						<p class="text-sm font-medium" style="color: hsl(var(--destructive));">{{ flash_error }}</p>
					</div>
				{% endfor %}

				{# ── Alerte succès (email vérifié) ── #}
				{% for message in app.flashes('success') %}
					<div class="flex items-start gap-3 p-4 mb-6 rounded-xl border" style="background-color: hsl(142 72% 50% / 0.10); border-color: hsl(142 72% 50% / 0.30);">
						<svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: hsl(142 72% 40%);" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
							<polyline points="22 4 12 14.01 9 11.01"/>
						</svg>
						<p class="text-sm font-medium" style="color: hsl(142 72% 35%);">{{ message }}</p>
					</div>
				{% endfor %}

				{# ── Formulaire ── #}
				{{ form_start(registrationForm, {
                attr: {
                    class: 'space-y-5',
                    novalidate: 'novalidate'
                }
            }) }}

                {# ── Champ Prénom ── #}
                <div>
                    {{ form_label(registrationForm.firstname, 'Prénom', {
                        label_attr: { class: 'block text-sm font-semibold text-foreground mb-1.5' }
                    }) }}
                    {{ form_widget(registrationForm.firstname, {
                        attr: {
                            class: 'w-full px-4 py-3 rounded-xl border text-sm font-body text-foreground bg-white transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-0',
                            style: 'border-color: hsl(var(--border)); --tw-ring-color: hsl(var(--primary) / 0.35);',
                            placeholder: 'Bruce'
                        }
                    }) }}
                    {{ form_errors(registrationForm.firstname) }}
                </div>

                {# ── Champ Nom ── #}
                <div>
                    {{ form_label(registrationForm.lastname, 'Nom', {
                        label_attr: { class: 'block text-sm font-semibold text-foreground mb-1.5' }
                    }) }}
                    {{ form_widget(registrationForm.lastname, {
                        attr: {
                            class: 'w-full px-4 py-3 rounded-xl border text-sm font-body text-foreground bg-white transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-0',
                            style: 'border-color: hsl(var(--border)); --tw-ring-color: hsl(var(--primary) / 0.35);',
                            placeholder: 'Wayne'
                        }
                    }) }}
                    {{ form_errors(registrationForm.lastname) }}
                </div>

				{# ── Champ Email ── #}
				<div>
					{{ form_label(registrationForm.email, 'Adresse email', {
                        label_attr: { class: 'block text-sm font-semibold text-foreground mb-1.5' }
                    }) }}
					<div class="relative">
						<div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
							<svg class="h-4 w-4 text-muted-foreground" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
								<polyline points="22,6 12,13 2,6"/>
							</svg>
						</div>
						{{ form_widget(registrationForm.email, {
                            attr: {
                                class: 'w-full pl-10 pr-4 py-3 rounded-xl border text-sm font-body text-foreground bg-white transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-0',
                                style: 'border-color: hsl(var(--border)); --tw-ring-color: hsl(var(--primary) / 0.35);',
                                placeholder: 'votre@email.com'
                            }
                        }) }}
					</div>
					{% if registrationForm.email.vars.errors|length > 0 %}
						<ul class="mt-1.5 space-y-0.5">
							{% for error in registrationForm.email.vars.errors %}
								<li class="flex items-center gap-1.5 text-xs font-medium" style="color: hsl(var(--destructive));">
									<svg class="h-3 w-3 flex-shrink-0" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<circle cx="12" cy="12" r="10"/>
										<line x1="12" y1="8" x2="12" y2="12"/>
										<line x1="12" y1="16" x2="12.01" y2="16"/>
									</svg>
									{{ error.message }}
								</li>
							{% endfor %}
						</ul>
					{% endif %}
				</div>

				{# ── Champ Mot de passe ── #}
				<div>
					{{ form_label(registrationForm.plainPassword, 'Mot de passe', {
                        label_attr: { class: 'block text-sm font-semibold text-foreground mb-1.5' }
                    }) }}

					<div class="relative" data-controller="password-toggle">
						<div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
							<svg class="h-4 w-4 text-muted-foreground" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
								<path d="M7 11V7a5 5 0 0 1 10 0v4"/>
							</svg>
						</div>
						{{ form_widget(registrationForm.plainPassword, {
                            attr: {
                                'data-password-toggle-target': 'input',
                                class: 'w-full pl-10 pr-12 py-3 rounded-xl border text-sm font-body text-foreground bg-white transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-0',
                                style: 'border-color: hsl(var(--border)); --tw-ring-color: hsl(var(--primary) / 0.35);',
                                placeholder: '••••••••'
                            }
                        }) }}
						<button type="button" data-action="click->password-toggle#toggle" data-password-toggle-target="button" aria-label="Afficher le mot de passe" aria-pressed="false" class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-muted-foreground hover:text-foreground transition-colors duration-200 focus:outline-none">
							<svg data-password-toggle-target="iconShow" class="h-4 w-4" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
								<circle cx="12" cy="12" r="3"/>
							</svg>
							<svg data-password-toggle-target="iconHide" class="h-4 w-4 hidden" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
								<path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
								<line x1="1" y1="1" x2="23" y2="23"/>
							</svg>
						</button>
					</div>
					<p class="mt-1.5 text-xs text-muted-foreground font-body">Minimum 6 caractères</p>
					{% if registrationForm.plainPassword.vars.errors|length > 0 %}
						<ul class="mt-1 space-y-0.5">
							{% for error in registrationForm.plainPassword.vars.errors %}
								<li class="flex items-center gap-1.5 text-xs font-medium" style="color: hsl(var(--destructive));">
									<svg class="h-3 w-3 flex-shrink-0" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<circle cx="12" cy="12" r="10"/>
										<line x1="12" y1="8" x2="12" y2="12"/>
										<line x1="12" y1="16" x2="12.01" y2="16"/>
									</svg>
									{{ error.message }}
								</li>
							{% endfor %}
						</ul>
					{% endif %}
				</div>

				{# ── Checkbox CGU ── #}
				<div class="flex items-start gap-3 p-4 rounded-xl border transition-colors" style="background-color: hsl(var(--muted) / 0.45); border-color: hsl(var(--border));">
					{{ form_widget(registrationForm.agreeTerms, {
                        attr: {
                            class: 'mt-0.5 h-4 w-4 rounded cursor-pointer flex-shrink-0',
                            style: 'accent-color: hsl(var(--primary));'
                        }
                    }) }}
					<div class="flex-1 min-w-0">
						{{ form_label(registrationForm.agreeTerms, "J'accepte les conditions d'utilisation", {
                            label_attr: { class: 'block text-sm font-semibold text-foreground cursor-pointer' }
                        }) }}
						<p class="text-xs text-muted-foreground mt-0.5 font-body">
							En créant votre compte, vous acceptez notre politique de confidentialité et nos CGU.
						</p>
					</div>
				</div>
				{% if registrationForm.agreeTerms.vars.errors|length > 0 %}
					<ul class="space-y-0.5 -mt-2">
						{% for error in registrationForm.agreeTerms.vars.errors %}
							<li class="flex items-center gap-1.5 text-xs font-medium" style="color: hsl(var(--destructive));">
								<svg class="h-3 w-3 flex-shrink-0" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<circle cx="12" cy="12" r="10"/>
									<line x1="12" y1="8" x2="12" y2="12"/>
									<line x1="12" y1="16" x2="12.01" y2="16"/>
								</svg>
								{{ error.message }}
							</li>
						{% endfor %}
					</ul>
				{% endif %}

				{# ── Bouton de soumission ── #}
				<button type="submit" class="w-full flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl text-white font-bold font-body text-base transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] shadow-primary-lg mt-2" style="background: linear-gradient(135deg, hsl(var(--primary)), hsl(var(--secondary)));">
					<svg class="h-5 w-5" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
						<circle cx="8.5" cy="7" r="4"/>
						<line x1="20" y1="8" x2="20" y2="14"/>
						<line x1="23" y1="11" x2="17" y2="11"/>
					</svg>
					Créer mon compte
				</button>

				{{ form_end(registrationForm) }}

				{# ── Lien retour accueil ── #}
				<p class="text-center mt-8 text-sm text-muted-foreground font-body">
					<a href="{{ path('app_home') }}" class="inline-flex items-center gap-1.5 font-medium hover:text-primary transition-colors duration-200">
						<svg class="h-3.5 w-3.5" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M19 12H5"/><path d="M12 5l-7 7 7 7"/>
						</svg>
						Retour à l'accueil
					</a>
				</p>
			</div>
		</div>

	</div>
{% endblock %}
