{% extends 'base.html.twig' %}

{% block title %}Connexion
{% endblock %}

{% block body %}
	<div
		class="min-h-screen flex flex-col lg:flex-row bg-background">

		{# ================================================================
		       COLONNE GAUCHE — héros décoratif (desktop uniquement)
		    ================================================================ #}
		<div
			class="hidden lg:flex lg:w-1/2 relative overflow-hidden items-center justify-center">

			{# Image de fond + overlays #}
			<div class="absolute inset-0" style="background-image: url('https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1200&q=85');
					                    background-size: cover; background-position: center;">
				<div class="absolute inset-0" style="background: linear-gradient(135deg,
					                     hsl(var(--accent) / 0.85) 0%,
					                     hsl(var(--primary) / 0.78) 55%,
					                     hsl(var(--secondary) / 0.88) 100%);"></div>
			</div>

			<div
				class="relative z-10 p-14 text-white max-w-md w-full">

				{# Logo #}
				<a href="{{ path('app_home') }}" class="flex items-center gap-3 mb-14 group">
					<div class="p-2.5 rounded-xl transition-transform duration-300 group-hover:scale-110" style="background: rgba(255,255,255,0.20);">
						<svg class="h-7 w-7 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="currentColor"/>
						</svg>
					</div>
					<span class="text-2xl font-bold font-heading">FanRead</span>
				</a>

				{# Accroche #}
				<h2 class="font-heading font-bold text-4xl mb-4 leading-tight">
					Bon retour<br>parmi vos livres.
				</h2>
				<p class="text-white/80 text-lg leading-relaxed mb-12 font-body">
					Retrouvez votre bibliothèque, vos notes et l'avancement de toutes vos lectures là où vous les avez laissées.
				</p>

				{# Stats fictives / motivantes #}
				<div class="grid grid-cols-3 gap-4">
					<div class="text-center p-4 rounded-2xl" style="background: rgba(255,255,255,0.15);">
						<p class="font-heading font-bold text-2xl text-white">2k+</p>
						<p class="text-white/70 text-xs font-body mt-0.5">Lecteurs</p>
					</div>
					<div class="text-center p-4 rounded-2xl" style="background: rgba(255,255,255,0.15);">
						<p class="font-heading font-bold text-2xl text-white">18k+</p>
						<p class="text-white/70 text-xs font-body mt-0.5">Livres</p>
					</div>
					<div class="text-center p-4 rounded-2xl" style="background: rgba(255,255,255,0.15);">
						<p class="font-heading font-bold text-2xl text-white">9</p>
						<p class="text-white/70 text-xs font-body mt-0.5">Catégories</p>
					</div>
				</div>
			</div>
		</div>

		{# ================================================================
		       COLONNE DROITE — formulaire
		    ================================================================ #}
		<div
			class="w-full lg:w-1/2 flex flex-col items-center justify-center min-h-screen p-6 sm:p-12 animate-fade-in-up">

			{# Logo mobile #}
			<div class="lg:hidden w-full max-w-md mb-10">
				<a href="{{ path('app_home') }}" class="flex items-center gap-2">
					<div class="p-2 rounded-xl bg-muted">
						<svg class="h-6 w-6 text-primary" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="currentColor"/>
						</svg>
					</div>
					<span class="text-2xl font-bold font-heading text-foreground">FanRead</span>
				</a>
			</div>

			<div
				class="w-full max-w-md">

				{# En-tête #}
				<div class="mb-8">
					<h1 class="font-heading font-bold text-3xl text-foreground mb-2">Se connecter</h1>
					<p class="text-muted-foreground font-body text-sm">
						Pas encore de compte ?
						<a href="{{ path('app_register') }}" class="text-primary font-semibold hover:underline underline-offset-2 transition-colors">
							Créer un compte
						</a>
					</p>
				</div>

				{# ── Alerte erreur d'authentification ── #}
				{% if error %}
					<div class="flex items-start gap-3 p-4 mb-6 rounded-xl border" style="background-color: hsl(var(--destructive) / 0.07); border-color: hsl(var(--destructive) / 0.30);">
						<svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: hsl(var(--destructive));" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="12" cy="12" r="10"/>
							<line x1="12" y1="8" x2="12" y2="12"/>
							<line x1="12" y1="16" x2="12.01" y2="16"/>
						</svg>
						<p class="text-sm font-medium" style="color: hsl(var(--destructive));">
							{{ error.messageKey|trans(error.messageData, 'security') }}
						</p>
					</div>
				{% endif %}

				{# ── Alerte succès (inscription réussie, etc.) ── #}
				{% for message in app.flashes('success') %}
					<div class="flex items-start gap-3 p-4 mb-6 rounded-xl border" style="background-color: hsl(142 72% 50% / 0.10); border-color: hsl(142 72% 50% / 0.30);">
						<svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: hsl(142 72% 40%);" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
							<polyline points="22 4 12 14.01 9 11.01"/>
						</svg>
						<p class="text-sm font-medium" style="color: hsl(142 72% 35%);">{{ message }}</p>
					</div>
				{% endfor %}

				{# ── Formulaire ── #}
				{# Le POST est intercepté par form_login de Symfony (check_path: app_login) #}
				<form
					method="post" action="{{ path('app_login') }}" class="space-y-5"
                    data-turbo="false">

					{# Token CSRF #}
                    <input
                        type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}"
                        data-controller="csrf-protection">

					{# ── Champ Email ── #}
					<div>
						<label for="inputEmail" class="block text-sm font-semibold text-foreground mb-1.5">
							Adresse email
						</label>
						<div class="relative">
							<div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
								<svg class="h-4 w-4 text-muted-foreground" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
									<polyline points="22,6 12,13 2,6"/>
								</svg>
							</div>
							<input type="email" id="inputEmail" name="_username" value="{{ last_username }}" autocomplete="email" required class="w-full pl-10 pr-4 py-3 rounded-xl border text-sm font-body text-foreground bg-white transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-0" style="border-color: hsl(var(--border)); --tw-ring-color: hsl(var(--primary) / 0.35);" placeholder="votre@email.com">
						</div>
					</div>

					{# ── Champ Mot de passe ── #}
					<div>
						<div class="flex items-center justify-between mb-1.5">
							<label for="inputPassword" class="block text-sm font-semibold text-foreground">
								Mot de passe
							</label>
							<a href="#" class="text-xs text-muted-foreground hover:text-primary transition-colors font-medium underline-offset-2 hover:underline">
								Mot de passe oublié ?
							</a>
						</div>

						<div class="relative" data-controller="password-toggle">
							<div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
								<svg class="h-4 w-4 text-muted-foreground" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
									<path d="M7 11V7a5 5 0 0 1 10 0v4"/>
								</svg>
							</div>
							<input type="password" id="inputPassword" name="_password" autocomplete="current-password" required data-password-toggle-target="input" class="w-full pl-10 pr-12 py-3 rounded-xl border text-sm font-body text-foreground bg-white transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-0" style="border-color: hsl(var(--border)); --tw-ring-color: hsl(var(--primary) / 0.35);" placeholder="••••••••">
							<button type="button" data-action="click->password-toggle#toggle" data-password-toggle-target="button" aria-label="Afficher le mot de passe" aria-pressed="false" class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-muted-foreground hover:text-foreground transition-colors duration-200 focus:outline-none">
								<svg data-password-toggle-target="iconShow" class="h-4 w-4" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
									<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
									<circle cx="12" cy="12" r="3"/>
								</svg>
								<svg data-password-toggle-target="iconHide" class="h-4 w-4 hidden" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
									<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
									<path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
									<line x1="1" y1="1" x2="23" y2="23"/>
								</svg>
							</button>
						</div>
					</div>

					{# ── Se souvenir de moi ── #}
					<div class="flex items-center gap-3 py-1">
						<input type="checkbox" id="remember_me" name="_remember_me" class="h-4 w-4 rounded cursor-pointer" style="accent-color: hsl(var(--primary));">
						<label for="remember_me" class="text-sm font-medium text-foreground cursor-pointer">
							Se souvenir de moi
							<span class="text-muted-foreground font-normal">(7 jours)</span>
						</label>
					</div>

					{# ── Bouton de soumission ── #}
					<button type="submit" class="w-full flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl text-white font-bold font-body text-base transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] shadow-primary-lg mt-2" style="background: linear-gradient(135deg, hsl(var(--accent)), hsl(var(--primary)));">
						<svg class="h-5 w-5" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
							<polyline points="10 17 15 12 10 7"/>
							<line x1="15" y1="12" x2="3" y2="12"/>
						</svg>
						Se connecter
					</button>

				</form>

				{# ── Lien retour accueil ── #}
				<p class="text-center mt-8 text-sm text-muted-foreground font-body">
					<a href="{{ path('app_home') }}" class="inline-flex items-center gap-1.5 font-medium hover:text-primary transition-colors duration-200">
						<svg class="h-3.5 w-3.5" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M19 12H5"/><path d="M12 5l-7 7 7 7"/>
						</svg>
						Retour à l'accueil
					</a>
				</p>
			</div>
		</div>

	</div>
{% endblock %}
