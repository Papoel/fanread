{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col lg:flex-row bg-background">

    {# ================================================================
           COLONNE GAUCHE — héros décoratif (desktop uniquement)
        ================================================================ #}
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden items-center justify-center">

        {# Image de fond + overlays #}
        <div class="absolute inset-0" style="background-image: url('https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1200&q=85');
                                background-size: cover; background-position: center;">
            <div class="absolute inset-0" style="background: linear-gradient(135deg,
                                     hsl(var(--secondary) / 0.88) 0%,
                                     hsl(var(--primary) / 0.80) 55%,
                                     hsl(var(--accent) / 0.85) 100%);"></div>
        </div>

        <div class="relative z-10 p-14 text-white max-w-md w-full">

            {# Logo #}
            <a href="{{ path('app_home') }}" class="flex items-center gap-3 mb-14 group">
                <div class="p-2.5 rounded-xl transition-transform duration-300 group-hover:scale-110" style="background: rgba(255,255,255,0.20);">
                    <svg class="h-7 w-7 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="currentColor"/>
                    </svg>
                </div>
                <span class="text-2xl font-bold font-heading">FanRead</span>
            </a>

            {# Accroche #}
            <h2 class="font-heading font-bold text-4xl mb-4 leading-tight">
                Choisissez<br>un mot de passe fort.
            </h2>
            <p class="text-white/80 text-lg leading-relaxed mb-12 font-body">
                Dernière étape ! Créez un mot de passe sécurisé pour protéger votre bibliothèque et vos lectures.
            </p>

            {# Conseils #}
            <ul class="space-y-4">
                <li class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.18);">
                        <svg class="w-4 h-4 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                    </div>
                    <span class="text-white/90 font-semibold font-body">Minimum 8 caractères</span>
                </li>
                <li class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.18);">
                        <svg class="w-4 h-4 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="9 11 12 14 22 4"/>
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                        </svg>
                    </div>
                    <span class="text-white/90 font-semibold font-body">Majuscules, chiffres et symboles</span>
                </li>
                <li class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.18);">
                        <svg class="w-4 h-4 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                    </div>
                    <span class="text-white/90 font-semibold font-body">Différent de vos anciens mots de passe</span>
                </li>
            </ul>
        </div>
    </div>

    {# ================================================================
           COLONNE DROITE — formulaire
        ================================================================ #}
    <div class="w-full lg:w-1/2 flex flex-col items-center justify-center min-h-screen p-6 sm:p-12 animate-fade-in-up">

        {# Logo mobile #}
        <div class="lg:hidden w-full max-w-md mb-10">
            <a href="{{ path('app_home') }}" class="flex items-center gap-2">
                <div class="p-2 rounded-xl bg-muted">
                    <svg class="h-6 w-6 text-primary" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="currentColor"/>
                    </svg>
                </div>
                <span class="text-2xl font-bold font-heading text-foreground">FanRead</span>
            </a>
        </div>

        <div class="w-full max-w-md">

            {# En-tête #}
            <div class="mb-8">
                <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5" style="background: linear-gradient(135deg, hsl(var(--accent) / 0.15), hsl(var(--primary) / 0.15));">
                    <svg class="w-7 h-7" style="color: hsl(var(--primary));" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                </div>
                <h1 class="font-heading font-bold text-3xl text-foreground mb-2">Nouveau mot de passe</h1>
                <p class="text-muted-foreground font-body text-sm">
                    Choisissez un mot de passe sécurisé pour votre compte <span class="font-semibold text-foreground">FanRead</span>.
                </p>
            </div>

            {# ── Alerte erreur flash ── #}
            {% for flash_error in app.flashes('reset_password_error') %}
                <div class="flex items-start gap-3 p-4 mb-6 rounded-xl border" style="background-color: hsl(var(--destructive) / 0.07); border-color: hsl(var(--destructive) / 0.30);">
                    <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: hsl(var(--destructive));" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    <p class="text-sm font-medium" style="color: hsl(var(--destructive));">{{ flash_error }}</p>
                </div>
            {% endfor %}

            {# ── Formulaire ── #}
            {{ form_start(resetForm, {'attr': {'class': 'space-y-5', 'novalidate': 'novalidate'}}) }}

                {# ── Erreur de correspondance des mots de passe ── #}
                {% if resetForm.plainPassword.vars.errors|length > 0 %}
                    <div class="flex items-start gap-3 p-4 rounded-xl border" style="background-color: hsl(var(--destructive) / 0.07); border-color: hsl(var(--destructive) / 0.30);">
                        <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: hsl(var(--destructive));" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        <ul class="list-none space-y-0.5">
                            {% for error in resetForm.plainPassword.vars.errors %}
                                <li class="text-sm font-medium" style="color: hsl(var(--destructive));">{{ error.message }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                {# ── Nouveau mot de passe ── #}
                <div data-controller="password-strength" data-password-strength-min-value="8">
                    <label for="{{ resetForm.plainPassword.first.vars.id }}" class="block text-sm font-semibold text-foreground mb-1.5">
                        Nouveau mot de passe
                    </label>
                    <div class="relative" data-controller="password-toggle">
                        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                            <svg class="h-4 w-4 text-muted-foreground" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                        </div>
                        {{ form_widget(resetForm.plainPassword.first, {
                            'attr': {
                                'class': 'w-full pl-10 pr-12 py-3 rounded-xl border text-sm font-body text-foreground bg-white transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-0',
                                'style': 'border-color: hsl(var(--border)); --tw-ring-color: hsl(var(--primary) / 0.35);',
                                'placeholder': '••••••••••••',
                                'data-password-toggle-target': 'input',
                                'data-password-strength-target': 'input',
                                'data-action': 'input->password-strength#evaluate'
                            }
                        }) }}
                        <button type="button" data-action="click->password-toggle#toggle" data-password-toggle-target="button" aria-label="Afficher le mot de passe" aria-pressed="false" class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-muted-foreground hover:text-foreground transition-colors duration-200 focus:outline-none" tabindex="-1">
                            <svg data-password-toggle-target="iconShow" class="h-4 w-4" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                            <svg data-password-toggle-target="iconHide" class="h-4 w-4 hidden" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                <line x1="1" y1="1" x2="23" y2="23"/>
                            </svg>
                        </button>
                    </div>

                    {# ── Jauge de force (Controller JS: password_strength_controller ── #}
                    <div class="mt-2">
                        <div class="flex items-center justify-between mb-1">
                            <div class="h-1.5 flex-1 rounded-full overflow-hidden mr-3" style="background-color: hsl(var(--muted));">
                                <div data-password-strength-target="bar"
                                    class="h-full rounded-full transition-all duration-500"
                                    style="width: 0; background-color: transparent;"></div>
                            </div>
                            <span data-password-strength-target="label"
                                class="text-xs font-semibold font-body w-20 text-right transition-colors duration-300"></span>
                        </div>
                        <ul class="grid grid-cols-2 gap-x-4 gap-y-1 mt-1">
                            <li data-password-strength-target="critLength"
                                class="flex items-center gap-1.5 text-xs font-body transition-colors duration-200"
                                style="color: hsl(var(--muted-foreground));">
                                <svg data-cross class="w-3 h-3 flex-shrink-0" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                <svg data-check class="w-3 h-3 flex-shrink-0 hidden" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                                8 caractères min.
                            </li>
                            <li data-password-strength-target="critUpper"
                                class="flex items-center gap-1.5 text-xs font-body transition-colors duration-200"
                                style="color: hsl(var(--muted-foreground));">
                                <svg data-cross class="w-3 h-3 flex-shrink-0" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                <svg data-check class="w-3 h-3 flex-shrink-0 hidden" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                                Majuscule
                            </li>
                            <li data-password-strength-target="critDigit"
                                class="flex items-center gap-1.5 text-xs font-body transition-colors duration-200"
                                style="color: hsl(var(--muted-foreground));">
                                <svg data-cross class="w-3 h-3 flex-shrink-0" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                <svg data-check class="w-3 h-3 flex-shrink-0 hidden" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                                Chiffre
                            </li>
                            <li data-password-strength-target="critSpecial"
                                class="flex items-center gap-1.5 text-xs font-body transition-colors duration-200"
                                style="color: hsl(var(--muted-foreground));">
                                <svg data-cross class="w-3 h-3 flex-shrink-0" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                <svg data-check class="w-3 h-3 flex-shrink-0 hidden" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                                Caractère spécial
                            </li>
                        </ul>
                    </div>
                    {% if resetForm.plainPassword.first.vars.errors|length > 0 %}
                        <div class="flex items-start gap-2 mt-1.5 p-3 rounded-lg border" style="background-color: hsl(var(--destructive) / 0.07); border-color: hsl(var(--destructive) / 0.30);">
                            <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: hsl(var(--destructive));" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                            <ul class="list-none space-y-0.5">
                                {% for error in resetForm.plainPassword.first.vars.errors %}
                                    <li class="text-xs font-medium" style="color: hsl(var(--destructive));">{{ error.message }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}
                </div>

                {# ── Confirmation mot de passe ── #}
                <div>
                    <label for="{{ resetForm.plainPassword.second.vars.id }}" class="block text-sm font-semibold text-foreground mb-1.5">
                        Confirmer le mot de passe
                    </label>
                    <div class="relative" data-controller="password-toggle">
                        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                            <svg class="h-4 w-4 text-muted-foreground" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                        </div>
                        {{ form_widget(resetForm.plainPassword.second, {
                            'attr': {
                                'class': 'w-full pl-10 pr-12 py-3 rounded-xl border text-sm font-body text-foreground bg-white transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-0',
                                'style': 'border-color: hsl(var(--border)); --tw-ring-color: hsl(var(--primary) / 0.35);',
                                'placeholder': '••••••••••••',
                                'data-password-toggle-target': 'input'
                            }
                        }) }}
                        <button type="button" data-action="click->password-toggle#toggle" data-password-toggle-target="button" aria-label="Afficher le mot de passe" aria-pressed="false" class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-muted-foreground hover:text-foreground transition-colors duration-200 focus:outline-none" tabindex="-1">
                            <svg data-password-toggle-target="iconShow" class="h-4 w-4" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                            <svg data-password-toggle-target="iconHide" class="h-4 w-4 hidden" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                <line x1="1" y1="1" x2="23" y2="23"/>
                            </svg>
                        </button>
                    </div>
                    {% if resetForm.plainPassword.second.vars.errors|length > 0 %}
                        <div class="flex items-start gap-2 mt-1.5 p-3 rounded-lg border" style="background-color: hsl(var(--destructive) / 0.07); border-color: hsl(var(--destructive) / 0.30);">
                            <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: hsl(var(--destructive));" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                            <ul class="list-none space-y-0.5">
                                {% for error in resetForm.plainPassword.second.vars.errors %}
                                    <li class="text-xs font-medium" style="color: hsl(var(--destructive));">{{ error.message }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}
                </div>

                {# ── Indicateur de force (visuel) ── #}
                <p class="text-xs text-muted-foreground font-body leading-relaxed">
                    Le mot de passe doit contenir au moins
                    <span class="font-semibold text-foreground">8 caractères</span>,
                    des majuscules, des chiffres et des caractères spéciaux.
                </p>

                {# ── Bouton de soumission ── #}
                <button type="submit" class="w-full flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl text-white font-bold font-body text-base transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] shadow-primary-lg mt-2" style="background: linear-gradient(135deg, hsl(var(--accent)), hsl(var(--primary)));">
                    <svg class="h-5 w-5" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                    Enregistrer le nouveau mot de passe
                </button>

            {{ form_end(resetForm) }}

            {# ── Lien retour connexion ── #}
            <p class="text-center mt-8 text-sm text-muted-foreground font-body">
                <a href="{{ path('app_login') }}" class="inline-flex items-center gap-1.5 font-medium hover:text-primary transition-colors duration-200">
                    <svg class="h-3.5 w-3.5" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5"/><path d="M12 5l-7 7 7 7"/>
                    </svg>
                    Retour à la connexion
                </a>
            </p>
        </div>
    </div>

</div>
{% endblock %}
