{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col lg:flex-row bg-background">

    {# ================================================================
           COLONNE GAUCHE — héros décoratif (desktop uniquement)
        ================================================================ #}
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden items-center justify-center">

        {# Image de fond + overlays #}
        <div class="absolute inset-0" style="background-image: url('https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1200&q=85');
                                background-size: cover; background-position: center;">
            <div class="absolute inset-0" style="background: linear-gradient(135deg,
                                     hsl(var(--secondary) / 0.88) 0%,
                                     hsl(var(--primary) / 0.80) 55%,
                                     hsl(var(--accent) / 0.85) 100%);"></div>
        </div>

        <div class="relative z-10 p-14 text-white max-w-md w-full">

            {# Logo #}
            <a href="{{ path('app_home') }}" class="flex items-center gap-3 mb-14 group">
                <div class="p-2.5 rounded-xl transition-transform duration-300 group-hover:scale-110" style="background: rgba(255,255,255,0.20);">
                    <svg class="h-7 w-7 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="currentColor"/>
                    </svg>
                </div>
                <span class="text-2xl font-bold font-heading">FanRead</span>
            </a>

            {# Accroche #}
            <h2 class="font-heading font-bold text-4xl mb-4 leading-tight">
                Retrouvez<br>votre accès.
            </h2>
            <p class="text-white/80 text-lg leading-relaxed mb-12 font-body">
                Pas de panique — ça arrive à tout le monde. Saisissez votre adresse email et nous vous enverrons un lien sécurisé pour réinitialiser votre mot de passe.
            </p>

            {# Étapes #}
            <ul class="space-y-4">
                <li class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.18);">
                        <svg class="w-4 h-4 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </div>
                    <span class="text-white/90 font-semibold font-body">Saisissez votre adresse email</span>
                </li>
                <li class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.18);">
                        <svg class="w-4 h-4 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                    </div>
                    <span class="text-white/90 font-semibold font-body">Recevez un lien sécurisé par email</span>
                </li>
                <li class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.18);">
                        <svg class="w-4 h-4 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                            <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                    </div>
                    <span class="text-white/90 font-semibold font-body">Créez votre nouveau mot de passe</span>
                </li>
            </ul>
        </div>
    </div>

    {# ================================================================
           COLONNE DROITE — formulaire
        ================================================================ #}
    <div class="w-full lg:w-1/2 flex flex-col items-center justify-center min-h-screen p-6 sm:p-12 animate-fade-in-up">

        {# Logo mobile #}
        <div class="lg:hidden w-full max-w-md mb-10">
            <a href="{{ path('app_home') }}" class="flex items-center gap-2">
                <div class="p-2 rounded-xl bg-muted">
                    <svg class="h-6 w-6 text-primary" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="currentColor"/>
                    </svg>
                </div>
                <span class="text-2xl font-bold font-heading text-foreground">FanRead</span>
            </a>
        </div>

        <div class="w-full max-w-md">

            {# En-tête #}
            <div class="mb-8">
                <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5" style="background: linear-gradient(135deg, hsl(var(--accent) / 0.15), hsl(var(--primary) / 0.15));">
                    <svg class="w-7 h-7" style="color: hsl(var(--primary));" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                </div>
                <h1 class="font-heading font-bold text-3xl text-foreground mb-2">Mot de passe oublié ?</h1>
                <p class="text-muted-foreground font-body text-sm">
                    Vous vous en souvenez finalement ?
                    <a href="{{ path('app_login') }}" class="text-primary font-semibold hover:underline underline-offset-2 transition-colors">
                        Se connecter
                    </a>
                </p>
            </div>

            {# ── Alerte erreur reset_password ── #}
            {% for flash_error in app.flashes('reset_password_error') %}
                <div class="flex items-start gap-3 p-4 mb-6 rounded-xl border" style="background-color: hsl(var(--destructive) / 0.07); border-color: hsl(var(--destructive) / 0.30);">
                    <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: hsl(var(--destructive));" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    <p class="text-sm font-medium" style="color: hsl(var(--destructive));">{{ flash_error }}</p>
                </div>
            {% endfor %}

            {# ── Formulaire ── #}
            {{ form_start(requestForm, {'attr': {'class': 'space-y-5', 'data-turbo': 'false', 'novalidate': 'novalidate'}}) }}

                {# ── Champ Email ── #}
                <div>
                    <label for="{{ requestForm.email.vars.id }}" class="block text-sm font-semibold text-foreground mb-1.5">
                        Adresse email
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                            <svg class="h-4 w-4 text-muted-foreground" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                        </div>
                        {{ form_widget(requestForm.email, {
                            'attr': {
                                'class': 'w-full pl-10 pr-4 py-3 rounded-xl border text-sm font-body text-foreground bg-white transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-0',
                                'style': 'border-color: hsl(var(--border)); --tw-ring-color: hsl(var(--primary) / 0.35);',
                                'placeholder': 'votre@email.com'
                            }
                        }) }}
                    </div>
                    {{ form_errors(requestForm.email) }}
                </div>

                {# ── Texte informatif ── #}
                <p class="text-xs text-muted-foreground font-body leading-relaxed">
                    Saisissez l'adresse email associée à votre compte. Nous vous enverrons un lien valable
                    <span class="font-semibold text-foreground">1 heure</span> pour réinitialiser votre mot de passe.
                </p>

                {# ── Bouton de soumission ── #}
                <button type="submit" class="w-full flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl text-white font-bold font-body text-base transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] shadow-primary-lg mt-2" style="background: linear-gradient(135deg, hsl(var(--accent)), hsl(var(--primary)));">
                    <svg class="h-5 w-5" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 17H2a3 3 0 0 0 3-3V9a7 7 0 0 1 14 0v5a3 3 0 0 0 3 3z"/>
                        <path d="M14 17v1a2 2 0 0 1-4 0v-1"/>
                    </svg>
                    Envoyer le lien de réinitialisation
                </button>

            {{ form_end(requestForm) }}

            {# ── Lien retour accueil ── #}
            <p class="text-center mt-8 text-sm text-muted-foreground font-body">
                <a href="{{ path('app_home') }}" class="inline-flex items-center gap-1.5 font-medium hover:text-primary transition-colors duration-200">
                    <svg class="h-3.5 w-3.5" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5"/><path d="M12 5l-7 7 7 7"/>
                    </svg>
                    Retour à l'accueil
                </a>
            </p>
        </div>
    </div>

</div>
{% endblock %}
