{% extends 'base.html.twig' %}

{% block title %}Email de réinitialisation envoyé{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col lg:flex-row bg-background">

    {# ================================================================
           COLONNE GAUCHE — héros décoratif (desktop uniquement)
        ================================================================ #}
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden items-center justify-center">

        {# Image de fond + overlays #}
        <div class="absolute inset-0" style="background-image: url('https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1200&q=85');
                                background-size: cover; background-position: center;">
            <div class="absolute inset-0" style="background: linear-gradient(135deg,
                                     hsl(var(--secondary) / 0.88) 0%,
                                     hsl(var(--primary) / 0.80) 55%,
                                     hsl(var(--accent) / 0.85) 100%);"></div>
        </div>

        <div class="relative z-10 p-14 text-white max-w-md w-full">

            {# Logo #}
            <a href="{{ path('app_home') }}" class="flex items-center gap-3 mb-14 group">
                <div class="p-2.5 rounded-xl transition-transform duration-300 group-hover:scale-110" style="background: rgba(255,255,255,0.20);">
                    <svg class="h-7 w-7 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="currentColor"/>
                    </svg>
                </div>
                <span class="text-2xl font-bold font-heading">FanRead</span>
            </a>

            {# Accroche #}
            <h2 class="font-heading font-bold text-4xl mb-4 leading-tight">
                Vérifiez<br>votre boîte mail.
            </h2>
            <p class="text-white/80 text-lg leading-relaxed mb-12 font-body">
                Le lien de réinitialisation est en route. Il ne vous reste plus qu'une étape avant de retrouver l'accès à votre bibliothèque.
            </p>

            {# Conseils #}
            <ul class="space-y-4">
                <li class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.18);">
                        <svg class="w-4 h-4 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </div>
                    <span class="text-white/90 font-semibold font-body">Consultez votre boîte de réception</span>
                </li>
                <li class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.18);">
                        <svg class="w-4 h-4 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="3 6 5 6 21 6"/>
                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                            <path d="M10 11v6"/><path d="M14 11v6"/>
                            <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                        </svg>
                    </div>
                    <span class="text-white/90 font-semibold font-body">Vérifiez aussi vos spams</span>
                </li>
                <li class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.18);">
                        <svg class="w-4 h-4 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <polyline points="12 6 12 12 16 14"/>
                        </svg>
                    </div>
                    <span class="text-white/90 font-semibold font-body">Le lien expire dans
                        {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}
                    </span>
                </li>
            </ul>
        </div>
    </div>

    {# ================================================================
           COLONNE DROITE — confirmation
        ================================================================ #}
    <div class="w-full lg:w-1/2 flex flex-col items-center justify-center min-h-screen p-6 sm:p-12 animate-fade-in-up">

        {# Logo mobile #}
        <div class="lg:hidden w-full max-w-md mb-10">
            <a href="{{ path('app_home') }}" class="flex items-center gap-2">
                <div class="p-2 rounded-xl bg-muted">
                    <svg class="h-6 w-6 text-primary" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="currentColor"/>
                    </svg>
                </div>
                <span class="text-2xl font-bold font-heading text-foreground">FanRead</span>
            </a>
        </div>

        <div class="w-full max-w-md">

            {# Icône de succès #}
            <div class="w-20 h-20 rounded-3xl flex items-center justify-center mx-auto mb-8" style="background: linear-gradient(135deg, hsl(142 72% 50% / 0.12), hsl(142 72% 50% / 0.20));">
                <svg class="w-10 h-10" style="color: hsl(142 72% 40%);" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
            </div>

            {# Titre & message principal #}
            <div class="text-center mb-8">
                <h1 class="font-heading font-bold text-3xl text-foreground mb-3">Email envoyé !</h1>
                <p class="text-muted-foreground font-body text-sm leading-relaxed">
                    Si un compte est associé à votre adresse email, vous allez recevoir un lien pour réinitialiser votre mot de passe.
                </p>
            </div>

            {# Carte info expiration #}
            <div class="rounded-2xl p-5 mb-6 space-y-3" style="background-color: hsl(var(--muted)); border: 1px solid hsl(var(--border));">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background: hsl(var(--primary) / 0.12);">
                        <svg class="w-4 h-4" style="color: hsl(var(--primary));" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <polyline points="12 6 12 12 16 14"/>
                        </svg>
                    </div>
                    <p class="text-sm font-body text-foreground">
                        Le lien expire dans
                        <span class="font-semibold">{{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}</span>.
                    </p>
                </div>
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background: hsl(var(--primary) / 0.12);">
                        <svg class="w-4 h-4" style="color: hsl(var(--primary));" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 14a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.06 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 10.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 18z"/>
                        </svg>
                    </div>
                    <p class="text-sm font-body text-foreground">
                        Vérifiez également votre <span class="font-semibold">dossier spam</span> si vous ne trouvez pas l'email.
                    </p>
                </div>
            </div>

            {# Bouton réessayer #}
            <a href="{{ path('app_forgot_password_request') }}" class="w-full flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl font-bold font-body text-sm transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] border" style="color: hsl(var(--primary)); border-color: hsl(var(--primary) / 0.35); background-color: hsl(var(--primary) / 0.06);">
                <svg class="h-4 w-4" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="1 4 1 10 7 10"/>
                    <path d="M3.51 15a9 9 0 1 0 .49-3.71"/>
                </svg>
                Renvoyer un email
            </a>

            {# ── Lien retour connexion ── #}
            <p class="text-center mt-6 text-sm text-muted-foreground font-body">
                <a href="{{ path('app_login') }}" class="inline-flex items-center gap-1.5 font-medium hover:text-primary transition-colors duration-200">
                    <svg class="h-3.5 w-3.5" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5"/><path d="M12 5l-7 7 7 7"/>
                    </svg>
                    Retour à la connexion
                </a>
            </p>
        </div>
    </div>

</div>
{% endblock %}
