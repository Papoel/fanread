<div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 gap-4">

                <div>
                    <h1 class="text-4xl md:text-5xl font-bold mb-3 text-foreground">
                        Ma Bibliothèque
                    </h1>
                    <p class="text-lg text-muted-foreground font-medium flex items-center gap-2">
                        {# Icône Library (Lucide SVG inline) #}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                        </svg>
                        {% set books = 25 %}
                        {{ books }} {{ books == 1 ? 'livre' : 'livres' }} dans votre collection
                    </p>
                </div>

                {# Onglets Tous / Coups de cœur — navigation par paramètre GET #}
                <div class="w-full md:w-auto">
                    <div class="bg-white border border-primary/10 p-1 rounded-xl shadow-sm inline-flex">

                        <a href="{{ path('app_book', app.request.query.all|merge({'tab': 'all'})) }}"
                           class="rounded-lg py-2 px-4 font-semibold transition-all flex items-center
                                  {{ activeTab == 'all'
                                      ? 'bg-primary/10 text-primary'
                                      : 'text-muted-foreground hover:text-foreground' }}">
                            {# Icône List #}
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="8" y1="6"  x2="21" y2="6" />
                                <line x1="8" y1="12" x2="21" y2="12"/>
                                <line x1="8" y1="18" x2="21" y2="18"/>
                                <line x1="3" y1="6"  x2="3.01" y2="6" />
                                <line x1="3" y1="12" x2="3.01" y2="12"/>
                                <line x1="3" y1="18" x2="3.01" y2="18"/>
                            </svg>
                            Tous
                        </a>

                        <a href="{{ path('app_book', app.request.query.all|merge({'tab': 'favorites'})) }}"
                           class="rounded-lg py-2 px-4 font-semibold transition-all flex items-center
                                  {{ activeTab == 'favorites'
                                      ? 'bg-secondary/10 text-secondary-foreground'
                                      : 'text-muted-foreground hover:text-foreground' }}">
                            {# Icône Heart #}
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06
                                         a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78
                                         1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                            </svg>
                            Coups de cœur
                        </a>

                    </div>
                </div>
            </div>
