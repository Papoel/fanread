{#
    templates/book/index.html.twig

    Variables attendues depuis le Controller :
    ──────────────────────────────────────────
    @var books[]         Liste complète des livres (pour le compteur)
    @var sortedBooks[]   Livres filtrés + triés par le Controller
        - id             int
        - title          string
        - category       string
        - status         string   ('en cours' | 'terminé')
        - isFavorite     bool
        - rating         int
        - dateAdded      \DateTimeInterface
    @var activeTab       string  ('all' | 'favorites')
    @var filterStatus    string  ('all' | 'en cours' | 'terminé')
    @var filterCategory  string
    @var sortBy          string  ('recent' | 'title' | 'rating')
    @var showForm        bool    (true si ?showForm=1)
#}

{% extends 'base.html.twig' %}

{% block title %}Mes livres{% endblock %}

{% block body %}

    {# ================================================================
       MAIN
    ================================================================ #}
    <div class="min-h-screen flex flex-col bg-background">
    {# ================================================================
       HEADER (navbar)
    ================================================================ #}
    {% include 'partials/_navbar.html.twig' %}

    <main class="flex-1 py-12">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">

            {# ── En-tête + onglets ──────────────────────────────────── #}
            {% include 'book/_header.html.twig' %}

            {# ── Bouton + formulaire d'ajout (toggle via Stimulus) ───── #}
            <div class="mb-10"
                data-controller="collapsible"
                data-collapsible-open-value="{{ showForm ? 'true' : 'false' }}">

                <button data-action="click->collapsible#toggle"
                        data-collapsible-target="trigger"
                        class="mb-4 transition-all duration-300 active:scale-95 font-semibold rounded-xl px-5 py-2.5 flex items-center gap-2
                            {{ showForm ? 'bg-muted text-foreground' : 'bg-primary text-white shadow-primary-lg' }}">
                    <svg data-collapsible-target="icon"
                        class="h-5 w-5 transition-transform duration-300"
                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    <span data-collapsible-target="label"
                        data-open-text="Fermer le formulaire"
                        data-closed-text="Ajouter une lecture">
                        {{ showForm ? 'Fermer le formulaire' : 'Ajouter une lecture' }}
                    </span>
                </button>

                <div data-collapsible-target="content"
                    class="{{ showForm ? '' : 'hidden' }} pt-2 pb-6">
                    {% include 'book/_form.html.twig' with { form: bookForm } only %}
                </div>

            </div>

            {# ── Barre de filtres (formulaire GET auto-submit) ────────── #}
            <form method="GET"
                  action="{{ path('app_book') }}"
                  data-controller="auto-submit"
                  class="bg-white p-4 rounded-2xl shadow-sm border border-primary/10 mb-8
                         flex flex-col md:flex-row gap-4 items-center justify-between flex-wrap">

                {# Conserver l'onglet actif #}
                {% if activeTab != 'all' %}
                    <input type="hidden" name="tab" value="{{ activeTab }}">
                {% endif %}

                <div class="flex flex-col sm:flex-row items-center gap-3 w-full md:w-auto">

                    <div class="flex items-center gap-2 w-full sm:w-auto text-muted-foreground font-medium">
                        {# Icône Filter #}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
                        </svg>
                        Filtres :
                    </div>

                    {# Filtre statut #}
                    {% set filterStatus = filterStatus|default('all') %}
                    <select name="status"
                            data-action="change->auto-submit#submit"
                            class="w-full sm:w-[160px] bg-background border border-primary/20 font-medium
                                   rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30">
                        <option value="all"       {{ filterStatus == 'all'       ? 'selected' : '' }}>Tous les statuts</option>
                        <option value="en cours"  {{ filterStatus == 'en cours'  ? 'selected' : '' }}>En cours</option>
                        <option value="terminé"   {{ filterStatus == 'terminé'   ? 'selected' : '' }}>Terminés</option>
                    </select>

                    {# Filtre catégorie #}
                    {% set filterCategory = filterCategory|default('Toutes catégories') %}
                    {% set categories = [
                        'Toutes catégories', 'Non classé', 'Romance', 'Fantasy', 'Thriller',
                        'Développement personnel', 'Science-fiction', 'Mystère', 'Jeunesse', 'Classique'
                    ] %}
                    <select name="category"
                            data-action="change->auto-submit#submit"
                            class="w-full sm:w-[180px] bg-background border border-primary/20 font-medium
                                   rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30">
                        {% for cat in categories %}
                            <option value="{{ cat }}" {{ filterCategory == cat ? 'selected' : '' }}>
                                {{ cat }}
                            </option>
                        {% endfor %}
                    </select>

                </div>

                {# Tri #}
                {% set sortBy = sortBy|default('recent') %}
                <div class="flex items-center gap-2 w-full md:w-auto">
                    <span class="text-sm text-muted-foreground font-medium hidden md:inline">Trier par :</span>
                    <select name="sort"
                            data-action="change->auto-submit#submit"
                            class="w-full sm:w-[160px] bg-background border border-primary/20 font-medium
                                   rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30">
                        <option value="recent" {{ sortBy == 'recent' ? 'selected' : '' }}>Plus récents</option>
                        <option value="title"  {{ sortBy == 'title'  ? 'selected' : '' }}>Titre (A-Z)</option>
                        <option value="rating" {{ sortBy == 'rating' ? 'selected' : '' }}>Mieux notés</option>
                    </select>
                </div>

            </form>

            {# ── Compteur résultats ───────────────────────────────────── #}
            {% set sortedBooks = sortedBooks|default([]) %}
            <div class="mb-6 flex items-center justify-between">
                <p class="text-sm font-semibold text-muted-foreground">
                    Affichage de {{ sortedBooks|length }}
                    {{ sortedBooks|length == 1 ? 'livre' : 'livres' }}
                </p>
            </div>

            {# ── Grille ou état vide ──────────────────────────────────── #}
            {% if sortedBooks|length == 0 %}

                <div class="text-center py-20 bg-white rounded-3xl border border-dashed border-primary/20">

                    <div class="rounded-full bg-accent/20 p-6 w-fit mx-auto mb-6">
                        {% if activeTab == 'favorites' %}
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-primary"
                                 viewBox="0 0 24 24" fill="currentColor" fill-opacity="0.2"
                                 stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06
                                         a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78
                                         1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                            </svg>
                        {% else %}
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-primary/60"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                            </svg>
                        {% endif %}
                    </div>

                    <h3 class="text-2xl font-bold mb-3 text-foreground">
                        {{ activeTab == 'favorites' ? 'Aucun coup de cœur' : 'Aucun livre trouvé' }}
                    </h3>

                    <p class="text-lg text-muted-foreground mb-8 max-w-md mx-auto">
                        {% if activeTab == 'favorites' %}
                            Vous n'avez pas encore ajouté de livres à vos favoris.
                            Cliquez sur le cœur d'un livre pour l'ajouter.
                        {% elseif filterStatus != 'all' or filterCategory != 'Toutes catégories' %}
                            Aucun livre ne correspond à vos filtres actuels.
                        {% else %}
                            Votre bibliothèque est encore vide. Commencez par ajouter une lecture !
                        {% endif %}
                    </p>

                    {# CTA : ajouter le premier livre #}
                    {% if activeTab == 'all' and filterStatus == 'all' and filterCategory == 'Toutes catégories' %}
                        <a href="{{ path('app_book', {'showForm': 1}) }}"
                           class="inline-flex items-center bg-primary hover:bg-primary/90 text-white
                                  rounded-xl shadow-lg shadow-primary/20 transition-all duration-300
                                  font-bold px-8 py-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="12" y1="5" x2="12" y2="19"/>
                                <line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                            Ajouter ma première lecture
                        </a>
                    {% endif %}

                    {# CTA : réinitialiser les filtres #}
                    {% if filterStatus != 'all' or filterCategory != 'Toutes catégories' %}
                        <a href="{{ path('app_book', {'tab': activeTab}) }}"
                           class="inline-flex items-center rounded-xl border border-primary/20 text-primary
                                  hover:bg-primary/5 font-semibold px-6 py-2 transition-all">
                            Réinitialiser les filtres
                        </a>
                    {% endif %}

                </div>

            {% else %}

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                    {% for book in sortedBooks %}
                        {% include 'book/_book_card.html.twig' with { book: book } only %}
                    {% endfor %}
                </div>

            {% endif %}

        </div>
    </main>

    {% include 'partials/_footer.html.twig' %}

</div>

{# Modal review — géré par votre propre implémentation Bootstrap/Twig #}
{# {% include 'book/_review_modal.html.twig' %} #}
{% endblock %}
