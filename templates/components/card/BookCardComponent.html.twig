{# Racine unique obligatoire pour les Live Components #}
<div {{ attributes }} class="relative group bg-white rounded-2xl border border-transparent overflow-hidden flex flex-col
		            transition-all duration-300
		            hover:shadow-xl hover:shadow-primary/10
		            hover:border-primary/20
		            {% if deleted %}hidden{% endif %}">

	{% if not deleted %}

		{# ── Couverture ──────────────────────────────────────────────── #}
		<div class="relative h-48 w-full bg-accent/20 flex items-center justify-center overflow-hidden shrink-0">

			{% if book.coverUrl %}
				<img src="{{ book.coverUrl }}" alt="{{ book.title }}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy">
			{% else %}
				<div class="flex flex-col items-center gap-2 text-muted-foreground/40">
					<svg class="h-12 w-12" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
						<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
						<path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
					</svg>
					<span class="text-xs font-medium uppercase tracking-wider font-body">Pas de couverture</span>
				</div>
			{% endif %}

			{# Gradient overlay #}
			<div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-80 pointer-events-none"></div>

			{# ── Bouton coup de cœur ── #}
			{{ component('FavoriteButtonComponent', { book: book }) }}

			{# Badge statut #}
			<span class="absolute bottom-3 right-3 px-2.5 py-1 rounded-full text-xs font-bold shadow-md
					                {{ book.status.value == 'termine' ? 'bg-secondary text-white' : 'bg-white text-foreground' }}">
				{{ book.status.label() }}
			</span>
		</div>

		{# ── Corps ────────────────────────────────────────────────────── #}
		<div class="p-5 flex-1 flex flex-col">
			<div class="mb-4">
				<h3 class="text-xl font-bold font-heading leading-tight mb-1 text-foreground
						    group-hover:text-primary transition-colors line-clamp-2 min-h-[3.5rem]">
					{{ book.title }}
				</h3>
				{% if book.author %}
					<p class="text-sm font-medium text-muted-foreground mb-3 font-body">{{ book.author }}</p>
				{% endif %}
				{% if book.category %}
					<span class="inline-flex px-2.5 py-1 rounded-full text-xs font-semibold" style="background-color: hsl(var(--primary) / 0.07);
							                                color: hsl(var(--primary));
							                                border: 1px solid hsl(var(--primary) / 0.20);">
						{{ book.category.label() }}
					</span>
				{% endif %}
			</div>

			<div
				class="space-y-3">

				{# Barre de progression #}
				{% set total = book.totalPages ?? 0 %}
				{% set read  = book.pagesRead  ?? 0 %}
				{% set pct   = total > 0 ? min(read / total * 100, 100) : 0 %}
				<div>
					<div class="flex justify-between text-xs text-muted-foreground mb-1.5 font-body">
						<span>{{ read }}
							pages lues</span>
						<span class="font-semibold text-primary">{{ this.progressPercentage }}%</span>
						<span>{{ total }}
							pages</span>
					</div>

					<div class="w-full h-2 bg-muted rounded-full overflow-hidden">
						<div class="h-full bg-primary rounded-full transition-all duration-500" style="width: {{ this.progressPercentage }}%"></div>
					</div>
				</div>

				{# Étoiles #}
                <div class="flex items-center gap-2 bg-muted/30 px-2 py-1.5 rounded-lg">
                    <div class="flex gap-0.5">
                        {% for i in 1..5 %}
                            <button type="button"
                                    data-action="live#action"
                                    data-live-action-param="setRating"
                                    data-live-rating-param="{{ i }}"
                                    title="Noter {{ i }}/5"
                                    class="transition-transform hover:scale-125 active:scale-95 cursor-pointer">
                                <svg class="h-4 w-4 {{ i <= book.rating ? 'fill-secondary text-secondary' : 'fill-transparent text-muted-foreground/40 hover:text-secondary/60' }}" viewbox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                                </svg>
                            </button>
                        {% endfor %}
                    </div>
                    {% if book.rating > 0 %}
                        <span class="text-xs font-semibold text-muted-foreground">({{ book.rating }}/5)</span>
                    {% else %}
                        <span class="text-xs text-muted-foreground italic font-body">Non noté</span>
                    {% endif %}
                </div>
			</div>

            {# Extrait review #}
            {% if book.review %}
            <details class="review-toggle text-sm text-foreground/80 italic bg-accent/10 p-3 rounded-xl border border-accent/20 mt-5">
                <summary class="cursor-pointer marker:hidden list-none">
                    <span class="review-short">"{{ book.review|u.truncate(50, '...') }}"</span>
                    <span class="review-full">"{{ book.review }}"</span>
                </summary>
            </details>
        {% endif %}
		</div>

		{# ── Pied : actions ───────────────────────────────────────────── #}
		<div class="px-4 pb-4 pt-2 border-t border-border">
			<div class="grid {{ book.description ? 'grid-cols-5' : 'grid-cols-4' }} gap-1.5">
				{# Modifier #}
				<button type="button" data-action="live#action" data-live-action-param="openEdit" title="Modifier" class="flex items-center justify-center p-2.5 rounded-xl transition-colors duration-150
						                            text-muted-foreground hover:bg-primary/10 hover:text-primary">
					<svg class="h-4 w-4" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
						<path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
					</svg>
				</button>

				{# Toggle statut #}
				<button type="button"
                        data-action="live#action"
                        data-live-action-param="toggleStatus"
                        title="{{ book.status.value == 'termine' ? 'Reprendre la lecture' : 'Marquer comme terminé' }}"
                        class="flex items-center justify-center p-2.5 rounded-xl transition-colors duration-150
                        {{ book.status.value == 'termine'
                            ? 'text-secondary hover:bg-secondary/15'
                            : 'text-muted-foreground hover:bg-secondary/15 hover:text-secondary' }}">
					{% if book.status.value == 'termine' %}
						<twig:ux:icon name="lucide:rotate-ccw" class="h-4 w-4"/>
					{% else %}
						<twig:ux:icon name="lucide:circle-check" class="h-4 w-4"/>
					{% endif %}
				</button>

				{# Avis #}
				<button type="button" data-action="live#action" data-live-action-param="openReview" title="Avis & notes" class="flex items-center justify-center p-2.5 rounded-xl transition-colors duration-150
						                            text-muted-foreground hover:bg-accent/30 hover:text-accent-foreground">
					<svg class="h-4 w-4" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
					</svg>
				</button>

                {# Lire la description #}
                {% if book.description %}
                    <button type="button" data-action="live#action" data-live-action-param="openDescription"
                            title="Lire la description"
                            class="flex items-center justify-center p-2.5 rounded-xl transition-colors duration-150
                                text-muted-foreground hover:bg-primary/10 hover:text-primary">
                        <twig:ux:icon name="lucide:book-open" class="h-4 w-4"/>
                    </button>
                {% endif %}

				{# Supprimer #}
				<button type="button" data-action="live#action" data-live-action-param="askDelete" title="Supprimer" class="flex items-center justify-center p-2.5 rounded-xl transition-colors duration-150
						                            text-muted-foreground hover:bg-destructive/10 hover:text-destructive">
					<svg class="h-4 w-4" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<polyline points="3 6 5 6 21 6"/>
						<path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
					</svg>
				</button>
			</div>
		</div>

		{% if confirmingDelete %}
			<div class="absolute inset-0 z-20 flex flex-col items-center justify-center gap-3
					                        rounded-2xl bg-white/2 backdrop-blur-sm p-4 text-center">
				<p class="text-sm font-semibold text-foreground">
					Supprimer «
					{{ book.title }}
					» ?
				</p>
				<div class="flex gap-2">
					<button type="button" data-action="live#action" data-live-action-param="delete" class="px-3 py-1.5 rounded-lg text-sm font-semibold bg-rose-600 text-white hover:bg-rose-700
							                                hover:opacity-90 transition-opacity">
						Supprimer
					</button>
					<button type="button" data-action="live#action" data-live-action-param="cancelDelete" class="px-3 py-1.5 rounded-lg text-sm font-semibold bg-muted text-foreground
							                                hover:bg-muted/80 transition-colors">
						Annuler
					</button>
				</div>
			</div>
		{% endif %}

		{# ── Modale Modifier ─────────────────────────────────────────── #}
		{% if editing %}
			{% set total = book.totalPages ?? 0 %}
			{% set read  = book.pagesRead  ?? 0 %}
			<div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50" data-action="live#action:prevent" data-live-action-param="closeModals">
				<div class="bg-white rounded-2xl shadow-xl w-full max-w-xl p-6 space-y-4" data-action="click->live#action:stop">
					<h3 class="font-heading font-bold text-xl text-foreground">
                        Modifier « {{ book.title }} »
                    </h3>

                    <div>
						<label class="block text-sm font-semibold mb-1.5">ISBN</label>
						<div class="relative">
							<input type="text" data-model="book.isbn" class="w-full pr-12 px-3 py-2 rounded-xl border text-sm" style="border-color: hsl(var(--border));">
							<button type="button" data-action="live#action:prevent" data-live-action-param="searchIsbn" title="Mettre à jour via Google Books" class="absolute inset-y-0 right-0 flex items-center justify-center w-11 rounded-r-xl
									                                        text-muted-foreground hover:text-primary transition-colors active:scale-95">
								<svg class="h-5 w-5" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
								</svg>
							</button>
						</div>
						{% if isbnStatus %}
							<p class="mt-1 text-xs font-medium" style="color: {{ isbnStatusType == 'error' ? 'hsl(var(--destructive))' : 'hsl(var(--secondary))' }};">
								{{ isbnStatus }}
							</p>
						{% endif %}
					</div>

					<div>
						<label class="block text-sm font-semibold mb-1.5">Pages lues</label>
						<input type="number" min="0" max="{{ total }}" data-model="book.pagesRead" class="w-full px-3 py-2 rounded-xl border text-sm" style="border-color: hsl(var(--border));">
						<div class="mt-2">
							<div class="flex justify-between text-xs text-muted-foreground mb-1">
								<span>Avancement</span>
								<span class="font-semibold text-primary">{{ this.progressPercentage }}%</span>
							</div>
							<div class="w-full h-2 bg-muted rounded-full overflow-hidden">
								<div class="h-full bg-primary rounded-full transition-all duration-300" style="width: {{ this.progressPercentage }}%"></div>
							</div>
						</div>
					</div>

					<div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
						<div>
							<label class="block text-sm font-semibold mb-1.5">Titre</label>
							<input type="text" data-model="book.title" class="w-full px-3 py-2 rounded-xl border text-sm" style="border-color: hsl(var(--border));">
						</div>
						<div>
							<label class="block text-sm font-semibold mb-1.5">Auteur</label>
							<input type="text" data-model="book.author" class="w-full px-3 py-2 rounded-xl border text-sm" style="border-color: hsl(var(--border));">
						</div>
						<div>
							<label class="block text-sm font-semibold mb-1.5">Pages totales</label>
							<input type="number" min="1" data-model="book.totalPages" class="w-full px-3 py-2 rounded-xl border text-sm" style="border-color: hsl(var(--border));">
						</div>
						<div>
							<label class="block text-sm font-semibold mb-1.5">Catégorie</label>
							<select data-model="categoryValue" class="w-full px-3 py-2 rounded-xl border text-sm" style="border-color: hsl(var(--border));">
								{% for cat in this.categories %}
									<option value="{{ cat.value }}" {{ categoryValue == cat.value ? 'selected' : '' }}>
										{{ cat.label() }}
									</option>
								{% endfor %}
							</select>
						</div>
					</div>

					<div>
						<label class="block text-sm font-semibold mb-1.5">URL de couverture</label>
						<input type="url" data-model="book.coverUrl" class="w-full px-3 py-2 rounded-xl border text-sm" style="border-color: hsl(var(--border));">
					</div>

                    <div>
                        <label class="block text-sm font-semibold mb-1.5">Description</label>
                        <textarea rows="5" data-model="book.description"
                                placeholder="Description du livre (ou laissez vide pour utiliser celle de Google Books)"
                                class="w-full px-3 py-2 rounded-xl border text-sm" style="border-color: hsl(var(--border));">{{ book.description }}</textarea>
                        <p class="mt-1 text-xs text-muted-foreground font-body">
                            Laissez ce champ vide pour récupérer la description de Google Books lors de la recherche par ISBN. Effacez son contenu pour rappatrier celle de l'API.
                        </p>
                    </div>


					<div class="flex gap-3 pt-2">
						<button type="button" data-action="live#action" data-live-action-param="saveEdit" class="flex-1 py-2.5 rounded-xl text-white font-bold" style="background: linear-gradient(135deg, hsl(var(--primary)), hsl(var(--secondary)));">
							Enregistrer
						</button>
						<button type="button" data-action="live#action" data-live-action-param="closeModals" class="px-5 py-2.5 rounded-xl text-sm font-semibold border" style="border-color: hsl(var(--border));">
							Annuler
						</button>
					</div>
				</div>
			</div>
		{% endif %}

		{# ── Modale Avis & Notes ─────────────────────────────────────── #}
		{% if reviewing %}
			<div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50" data-action="live#action:prevent" data-live-action-param="closeModals">
				<div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6 space-y-4" data-action="click->live#action:stop">
					<h3 class="font-heading font-bold text-xl text-foreground">{{ book.title }}</h3>

					<div>
						<label class="block text-sm font-semibold mb-1.5">Note</label>
						<div class="flex gap-1">
							{% for i in 1..5 %}
								<button type="button" data-action="live#action" data-live-action-param="setRating" data-live-rating-param="{{ i }}" class="transition-transform hover:scale-110">
									<svg class="h-7 w-7 {{ i <= book.rating ? 'fill-secondary text-secondary' : 'fill-transparent text-muted-foreground/40' }}" viewbox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
										<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
									</svg>
								</button>
							{% endfor %}
						</div>
					</div>

					<div>
						<label class="block text-sm font-semibold mb-1.5">Votre avis</label>
						<textarea rows="4" data-model="book.review" placeholder="Partagez vos impressions sur ce livre..." class="w-full px-3 py-2 rounded-xl border text-sm" style="border-color: hsl(var(--border));"></textarea>
					</div>

					<div class="flex gap-3 pt-2">
						<button type="button" data-action="live#action" data-live-action-param="saveReview" class="flex-1 py-2.5 rounded-xl text-white font-bold" style="background: linear-gradient(135deg, hsl(var(--primary)), hsl(var(--secondary)));">
							Enregistrer
						</button>
						<button type="button" data-action="live#action" data-live-action-param="closeModals" class="px-5 py-2.5 rounded-xl text-sm font-semibold border" style="border-color: hsl(var(--border));">
							Annuler
						</button>
					</div>
				</div>
			</div>
		{% endif %}

        {# ── Modale Description ──────────────────────────────────────── #}
        {% if showingDescription %}
            <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm"
                data-action="live#action:prevent" data-live-action-param="closeModals">
                <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg max-h-[85vh] flex flex-col overflow-hidden"
                    data-action="click->live#action:stop">

                    {# En-tête avec couverture #}
                    <div class="flex items-start gap-4 p-6 border-b" style="border-color: hsl(var(--border));">
                        {% if book.coverUrl %}
                            <img src="{{ book.coverUrl }}" alt="{{ book.title }}"
                                class="h-24 w-16 object-cover rounded-lg shadow-md shrink-0">
                        {% endif %}
                        <div class="min-w-0">
                            <h3 class="font-heading font-bold text-xl text-foreground leading-tight">{{ book.title }}</h3>
                            {% if book.author %}
                                <p class="text-sm text-muted-foreground mt-1 font-body">{{ book.author }}</p>
                            {% endif %}
                        </div>
                        <button type="button" data-action="live#action:prevent" data-live-action-param="closeModals"
                                title="Fermer"
                                class="ml-auto shrink-0 text-muted-foreground hover:text-foreground transition-colors">
                            <twig:ux:icon name="lucide:x" class="h-5 w-5"/>
                        </button>
                    </div>

                    {# Corps : description scrollable #}
                    <div class="p-6 overflow-y-auto">
                        <p class="text-sm text-foreground/80 leading-relaxed whitespace-pre-line font-body">
                            {{ book.description }}
                        </p>
                    </div>
                </div>
            </div>
        {% endif %}
	{% endif %}
</div>
