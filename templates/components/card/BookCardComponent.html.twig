{# Racine unique obligatoire pour les Live Components #}
<div {{ attributes }}
     class="relative group bg-white rounded-2xl border border-transparent overflow-hidden flex flex-col
            transition-all duration-300
            hover:shadow-xl hover:shadow-primary/10
            hover:border-primary/20
            {% if deleted %}hidden{% endif %}">

    {% if not deleted %}

        {# ── Couverture ──────────────────────────────────────────────── #}
        <div class="relative h-48 w-full bg-accent/20 flex items-center justify-center overflow-hidden shrink-0">

            {% if book.coverUrl %}
                <img src="{{ book.coverUrl }}"
                    alt="{{ book.title }}"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy">
            {% else %}
                <div class="flex flex-col items-center gap-2 text-muted-foreground/40">
                    <svg class="h-12 w-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                    </svg>
                    <span class="text-xs font-medium uppercase tracking-wider font-body">Pas de couverture</span>
                </div>
            {% endif %}

            {# Gradient overlay #}
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-80 pointer-events-none"></div>

            {# ── Bouton coup de cœur ── #}
            {{ component('FavoriteButtonComponent', { book: book }) }}

            {# Badge statut #}
            <span class="absolute bottom-3 right-3 px-2.5 py-1 rounded-full text-xs font-bold shadow-md
                {{ book.status.value == 'termine' ? 'bg-secondary text-white' : 'bg-white text-foreground' }}">
                {{ book.status.label() }}
            </span>
        </div>

        {# ── Corps ────────────────────────────────────────────────────── #}
        <div class="p-5 flex-1 flex flex-col">
            <div class="mb-4">
                <h3 class="text-xl font-bold font-heading leading-tight mb-1 text-foreground
                        group-hover:text-primary transition-colors line-clamp-2">
                    {{ book.title }}
                </h3>
                {% if book.author %}
                    <p class="text-sm font-medium text-muted-foreground mb-3 font-body">{{ book.author }}</p>
                {% endif %}
                {% if book.category %}
                    <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-semibold"
                        style="background-color: hsl(var(--primary) / 0.07);
                                color: hsl(var(--primary));
                                border: 1px solid hsl(var(--primary) / 0.20);">
                        {{ book.category.label() }}
                    </span>
                {% endif %}
            </div>

            <div class="space-y-3 mt-auto">

                {# Barre de progression #}
                {% set total = book.totalPages ?? 0 %}
                {% set read  = book.pagesRead  ?? 0 %}
                {% set pct   = total > 0 ? min(read / total * 100, 100) : 0 %}
                <div>
                    <div class="flex justify-between text-xs text-muted-foreground mb-1.5 font-body">
                        <span>{{ read }} pages lues</span>
                        <span>{{ total }} pages</span>
                    </div>

                    <div class="w-full h-2 bg-muted rounded-full overflow-hidden">
                        <div class="h-full bg-primary rounded-full transition-all duration-500"
                            style="width: {{ pct|number_format(1) }}%"></div>
                    </div>
                </div>

                {# Étoiles #}
                <div class="flex items-center gap-2 bg-muted/30 px-2 py-1.5 rounded-lg">
                    <div class="flex gap-0.5">
                        {% for i in 1..5 %}
                            <svg class="h-4 w-4 {{ i <= book.rating ? 'fill-secondary text-secondary' : 'fill-transparent text-muted-foreground/40' }}"
                                viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                        {% endfor %}
                    </div>
                    {% if book.rating > 0 %}
                        <span class="text-xs font-semibold text-muted-foreground">({{ book.rating }}/5)</span>
                    {% else %}
                        <span class="text-xs text-muted-foreground italic font-body">Non noté</span>
                    {% endif %}
                </div>

                {# Extrait review #}
                {% if book.review %}
                    <p class="text-xs text-foreground/75 line-clamp-2 italic
                            bg-accent/10 px-3 py-2 rounded-xl border border-accent/20 font-body">
                        "{{ book.review }}"
                    </p>
                {% endif %}

            </div>
        </div>

        {# ── Pied : actions ───────────────────────────────────────────── #}
        <div class="px-4 pb-4 pt-2 border-t border-border">
            <div class="grid grid-cols-4 gap-1.5">
                {# Modifier — désactivé (step suivant) #}
                <button type="button" disabled title="Modifier (bientôt disponible)"
                        class="flex items-center justify-center p-2.5 rounded-xl
                            text-muted-foreground/40 cursor-not-allowed">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                </button>

                {# Toggle statut #}
                <button type="button"
                        data-action="live#action"
                        data-live-action-param="toggleStatus"
                        title="{{ book.status.value == 'termine' ? 'Reprendre la lecture' : 'Marquer comme terminé' }}"
                        class="flex items-center justify-center p-2.5 rounded-xl transition-colors duration-150
                            {{ book.status.value == 'termine'
                                ? 'text-secondary hover:bg-secondary/15'
                                : 'text-muted-foreground hover:bg-secondary/15 hover:text-secondary' }}">
                    {% if book.status.value == 'termine' %}
                        <twig:ux:icon name="lucide:rotate-ccw" class="h-4 w-4" />
                    {% else %}
                        <twig:ux:icon name="lucide:circle-check" class="h-4 w-4" />
                    {% endif %}
                </button>

                {# Avis — désactivé (step suivant) #}
                <button type="button" disabled title="Avis & notes (bientôt disponible)"
                        class="flex items-center justify-center p-2.5 rounded-xl
                            text-muted-foreground/40 cursor-not-allowed">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                    </svg>
                </button>

                {# Supprimer #}
                <button type="button"
                        data-action="live#action"
                        data-live-action-param="askDelete"
                        title="Supprimer"
                        class="flex items-center justify-center p-2.5 rounded-xl transition-colors duration-150
                            text-muted-foreground hover:bg-destructive/10 hover:text-destructive">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                    </svg>
                </button>
            </div>
        </div>

        {% if confirmingDelete %}
            <div class="absolute inset-0 z-20 flex flex-col items-center justify-center gap-3
                        rounded-2xl bg-white/2 backdrop-blur-sm p-4 text-center">
                <p class="text-sm font-semibold text-foreground">
                    Supprimer « {{ book.title }} » ?
                </p>
                <div class="flex gap-2">
                    <button type="button"
                            data-action="live#action" data-live-action-param="delete"
                            class="px-3 py-1.5 rounded-lg text-sm font-semibold bg-rose-600 text-white hover:bg-rose-700
                                hover:opacity-90 transition-opacity">
                        Supprimer
                    </button>
                    <button type="button"
                            data-action="live#action" data-live-action-param="cancelDelete"
                            class="px-3 py-1.5 rounded-lg text-sm font-semibold bg-muted text-foreground
                                hover:bg-muted/80 transition-colors">
                        Annuler
                    </button>
                </div>
            </div>
        {% endif %}

    {% endif %}
</div>
